<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Ask Pradnya — AI Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0a0a0a;
  --surface:#141414;
  --surface2:#1a1a1a;
  --surface3:#222;
  --surface4:#2a2a2a;
  --border:rgba(255,255,255,0.07);
  --border2:rgba(255,255,255,0.12);
  --border3:rgba(255,255,255,0.18);
  --text:#edeae4;
  --text2:#807872;
  --text3:#4a4440;
  --accent:#e8d5b0;
  --accent-dim:rgba(232,213,176,0.1);
  --green:#4ade80;
  --send:#e8d5b0;
  --send-fg:#0a0a0a;
  --orange:#f97316;
}
html,body{height:100%;}
body{font-family:'Inter',-apple-system,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column;align-items:center;-webkit-font-smoothing:antialiased;}

/* PAGE */
.page{width:100%;max-width:640px;padding:0 24px;display:flex;flex-direction:column;align-items:center;}

/* HERO */
.hero{width:100%;display:flex;flex-direction:column;align-items:center;text-align:center;padding:88px 0 0;animation:up .55s cubic-bezier(.16,1,.3,1) both;}
.av{width:62px;height:62px;border-radius:50%;background:var(--surface2);border:1.5px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:600;letter-spacing:.5px;color:var(--accent);margin-bottom:20px;}
.badge{display:inline-flex;align-items:center;gap:7px;background:var(--surface);border:1px solid var(--border2);border-radius:99px;padding:5px 14px 5px 11px;font-size:11.5px;font-weight:500;color:var(--text2);letter-spacing:.02em;margin-bottom:28px;}
.bdot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 7px rgba(74,222,128,.5);animation:breathe 2.5s ease infinite;}
.hero h1{font-size:clamp(26px,4.8vw,42px);font-weight:400;line-height:1.18;letter-spacing:-.4px;color:var(--text);margin-bottom:12px;}
.hero h1 .dim{color:var(--text2);}
.hero .sub{font-size:14px;color:var(--text2);font-weight:400;line-height:1.6;max-width:360px;margin-bottom:0;}

/* TOP NAV TABS */
.tab-row{display:flex;flex-wrap:wrap;justify-content:center;gap:0;margin:32px 0 0;width:100%;border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:2px 0;}
.tab{display:inline-flex;align-items:center;padding:10px 18px;font-size:13px;font-weight:400;color:var(--text2);cursor:pointer;font-family:'Inter',sans-serif;background:transparent;border:none;text-decoration:none;transition:color .15s;white-space:nowrap;position:relative;}
.tab::after{content:'';position:absolute;bottom:-2px;left:0;right:0;height:2px;background:var(--accent);transform:scaleX(0);transition:transform .2s;border-radius:2px;}
.tab:hover{color:var(--text);}
.tab:hover::after,.tab.active::after{transform:scaleX(1);}
.tab.active{color:var(--text);}
.tab-sep{width:1px;background:var(--border);align-self:stretch;margin:6px 0;flex-shrink:0;}

/* CHAT */
.chat{width:100%;padding-bottom:140px;margin-top:32px;animation:up .5s .05s cubic-bezier(.16,1,.3,1) both;}
.sep{display:flex;align-items:center;gap:10px;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:28px;}
.sep::before,.sep::after{content:'';flex:1;height:1px;background:var(--border);}
.msgs{display:flex;flex-direction:column;gap:14px;}
.row{display:flex;gap:11px;align-items:flex-end;animation:up .28s ease both;}
.row.user{flex-direction:row-reverse;}
.row-av{width:28px;height:28px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10.5px;font-weight:600;}
.row.ai .row-av{background:var(--surface2);color:var(--accent);border:1px solid var(--border2);}
.row.user .row-av{background:var(--surface);color:var(--text2);border:1px solid var(--border);}
.bwrap{display:flex;flex-direction:column;gap:10px;max-width:82%;}
.row.user .bwrap{align-items:flex-end;}
.bub{padding:12px 16px;border-radius:16px;font-size:13.5px;line-height:1.7;font-weight:400;}
.row.ai .bub{background:var(--surface);color:var(--text);border:1px solid var(--border);border-bottom-left-radius:4px;}
.row.user .bub{background:var(--surface2);color:var(--text);border:1px solid var(--border);border-bottom-right-radius:4px;}
.bub strong{font-weight:500;color:var(--accent);}
.bub ul{padding-left:16px;margin:5px 0;}
.bub li{margin:4px 0;}

/* AFTER-REPLY TABS */
.atabs{display:flex;flex-wrap:wrap;gap:6px;animation:up .3s .08s ease both;}
.atab{display:inline-flex;align-items:center;gap:5px;background:var(--surface2);border:1px solid var(--border2);border-radius:99px;padding:6px 13px;font-size:12px;font-weight:500;color:var(--text2);text-decoration:none;cursor:pointer;font-family:'Inter',sans-serif;transition:background .15s,color .15s,transform .15s;white-space:nowrap;}
.atab:hover{background:var(--surface3);color:var(--text);transform:translateY(-1px);}
.atab-arr{font-size:11px;opacity:.5;transition:opacity .15s,transform .15s;}
.atab:hover .atab-arr{opacity:1;transform:translateX(2px);}

/* ── CASE STUDY CARDS SECTION ── */
.cs-section{width:100%;margin-top:4px;animation:up .28s ease both;}

.cs-section-header{
  display:flex;align-items:center;gap:8px;
  margin-bottom:16px;
  padding-bottom:12px;
  border-bottom:1px solid var(--border);
}
.cs-tag{
  font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;
  color:var(--orange);background:rgba(249,115,22,.1);
  border:1px solid rgba(249,115,22,.2);border-radius:4px;padding:3px 8px;
}

.cs-grid{display:flex;flex-direction:column;gap:12px;}

/* Individual case study card */
.cs-card{
  background:var(--surface);border:1px solid var(--border2);border-radius:14px;
  padding:20px;cursor:pointer;
  transition:border-color .2s,background .2s,transform .15s;
  position:relative;overflow:hidden;
}
.cs-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--orange),rgba(249,115,22,0));
  opacity:0;transition:opacity .2s;
}
.cs-card:hover{border-color:var(--border3);background:var(--surface2);transform:translateY(-1px);}
.cs-card:hover::before{opacity:1;}

.cs-card-cat{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--orange);margin-bottom:8px;}
.cs-card-title{font-size:16px;font-weight:500;color:var(--text);margin-bottom:6px;line-height:1.3;}
.cs-card-desc{font-size:13px;color:var(--text2);line-height:1.6;margin-bottom:14px;}
.cs-card-meta{display:flex;gap:16px;flex-wrap:wrap;}
.cs-meta-item{display:flex;flex-direction:column;gap:2px;}
.cs-meta-label{font-size:10.5px;color:var(--text3);font-weight:500;letter-spacing:.04em;text-transform:uppercase;}
.cs-meta-value{font-size:12.5px;color:var(--text2);}
.cs-card-footer{
  display:flex;justify-content:flex-end;
  margin-top:14px;padding-top:14px;
  border-top:1px solid var(--border);
}
.cs-view-btn{
  display:inline-flex;align-items:center;gap:5px;
  font-size:12px;font-weight:500;color:var(--accent);
  background:var(--accent-dim);border:1px solid rgba(232,213,176,.15);
  border-radius:99px;padding:6px 14px;
  transition:background .15s,transform .15s;
  cursor:pointer;font-family:'Inter',sans-serif;
}
.cs-view-btn:hover{background:rgba(232,213,176,.18);transform:translateX(2px);}

.cs-behance-link{
  display:inline-flex;align-items:center;gap:6px;
  font-size:12.5px;color:var(--text2);margin-top:14px;
  text-decoration:none;transition:color .15s;
  cursor:pointer;background:none;border:none;font-family:'Inter',sans-serif;
}
.cs-behance-link:hover{color:var(--text);}

/* ── CASE STUDY DETAIL PANEL ── */
.cs-overlay{
  position:fixed;inset:0;z-index:100;
  background:rgba(0,0,0,0.7);
  backdrop-filter:blur(4px);
  -webkit-backdrop-filter:blur(4px);
  display:flex;align-items:flex-end;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity .25s ease;
}
.cs-overlay.open{opacity:1;pointer-events:all;}

.cs-panel{
  width:100%;max-width:700px;
  max-height:92vh;
  background:var(--surface);
  border:1px solid var(--border2);
  border-radius:20px 20px 0 0;
  display:flex;flex-direction:column;
  transform:translateY(40px);
  transition:transform .3s cubic-bezier(.16,1,.3,1);
  overflow:hidden;
}
.cs-overlay.open .cs-panel{transform:translateY(0);}

/* Panel header */
.cs-panel-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:18px 24px 16px;
  border-bottom:1px solid var(--border);
  flex-shrink:0;
}
.cs-panel-cat{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--orange);}
.cs-close{
  width:32px;height:32px;border-radius:50%;
  background:var(--surface3);border:1px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--text2);font-size:16px;
  transition:background .15s,color .15s;flex-shrink:0;
}
.cs-close:hover{background:var(--surface4);color:var(--text);}

/* Panel scrollable body */
.cs-panel-body{
  overflow-y:auto;
  padding:24px 24px 0;
  flex:1;
}
.cs-panel-body::-webkit-scrollbar{width:4px;}
.cs-panel-body::-webkit-scrollbar-track{background:transparent;}
.cs-panel-body::-webkit-scrollbar-thumb{background:var(--surface4);border-radius:4px;}

.cs-panel-title{font-size:22px;font-weight:500;color:var(--text);line-height:1.25;margin-bottom:20px;}

/* Meta grid */
.cs-detail-meta{
  display:grid;grid-template-columns:repeat(3,1fr);gap:12px;
  background:var(--surface2);border:1px solid var(--border);border-radius:12px;
  padding:16px;margin-bottom:24px;
}
.cs-dm-item{}
.cs-dm-label{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);margin-bottom:4px;}
.cs-dm-value{font-size:13px;font-weight:500;color:var(--text2);}

/* Sections */
.cs-section-block{margin-bottom:24px;}
.cs-section-block h3{font-size:12px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border);}
.cs-section-block p{font-size:13.5px;color:var(--text2);line-height:1.72;}
.cs-section-block p+p{margin-top:10px;}

/* Problem statement */
.problem-box{
  background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.15);
  border-radius:10px;padding:14px 16px;
  font-size:13.5px;color:var(--text2);line-height:1.7;
  margin-bottom:24px;
}
.problem-box strong{color:var(--orange);font-weight:500;}

/* Key decisions */
.decisions{display:flex;flex-direction:column;gap:10px;margin-top:2px;}
.decision-item{
  background:var(--surface2);border:1px solid var(--border);border-radius:10px;
  padding:14px 16px;display:flex;gap:12px;align-items:flex-start;
}
.decision-num{
  width:26px;height:26px;border-radius:50%;
  background:var(--accent-dim);border:1px solid rgba(232,213,176,.2);
  display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:600;color:var(--accent);flex-shrink:0;margin-top:1px;
}
.decision-content h4{font-size:13px;font-weight:500;color:var(--text);margin-bottom:4px;}
.decision-content p{font-size:13px;color:var(--text2);line-height:1.65;}

/* Outcome pills */
.outcomes{display:flex;flex-direction:column;gap:8px;margin-top:4px;}
.outcome-item{
  display:flex;align-items:flex-start;gap:10px;
  background:rgba(74,222,128,.05);border:1px solid rgba(74,222,128,.12);
  border-radius:8px;padding:10px 14px;
  font-size:13px;color:var(--text2);line-height:1.6;
}
.outcome-item::before{content:'↑';color:#4ade80;font-weight:600;font-size:13px;flex-shrink:0;margin-top:1px;}

/* Panel footer */
.cs-panel-footer{
  padding:16px 24px 28px;
  border-top:1px solid var(--border);
  display:flex;gap:10px;align-items:center;
  flex-shrink:0;
  background:var(--surface);
}
.cs-dl-btn{
  display:inline-flex;align-items:center;gap:7px;
  background:var(--send);color:var(--send-fg);
  border:none;border-radius:10px;
  padding:10px 20px;font-size:13px;font-weight:600;
  cursor:pointer;font-family:'Inter',sans-serif;
  text-decoration:none;
  transition:opacity .15s,transform .15s;
}
.cs-dl-btn:hover{opacity:.88;transform:translateY(-1px);}
.cs-behance-btn{
  display:inline-flex;align-items:center;gap:6px;
  background:transparent;border:1px solid var(--border2);border-radius:10px;
  padding:10px 18px;font-size:13px;font-weight:500;color:var(--text2);
  cursor:pointer;font-family:'Inter',sans-serif;text-decoration:none;
  transition:background .15s,color .15s;
}
.cs-behance-btn:hover{background:var(--surface2);color:var(--text);}
.cs-close-btn{
  margin-left:auto;
  display:inline-flex;align-items:center;gap:6px;
  background:transparent;border:1px solid var(--border);border-radius:10px;
  padding:10px 18px;font-size:13px;font-weight:400;color:var(--text3);
  cursor:pointer;font-family:'Inter',sans-serif;
  transition:background .15s,color .15s;
}
.cs-close-btn:hover{background:var(--surface2);color:var(--text2);}

/* TYPING */
.t-row{display:flex;gap:11px;align-items:flex-end;}
.t-bub{background:var(--surface);border:1px solid var(--border);border-radius:16px;border-bottom-left-radius:4px;padding:14px 16px;display:flex;gap:5px;align-items:center;}
.td{width:5px;height:5px;border-radius:50%;background:var(--text3);animation:tdot 1.3s ease infinite;}
.td:nth-child(2){animation-delay:.18s;}
.td:nth-child(3){animation-delay:.36s;}

/* INPUT BAR */
.bar{position:fixed;bottom:0;left:0;right:0;z-index:20;padding:10px 24px 28px;background:linear-gradient(to top,var(--bg) 62%,transparent);}
.bar-inner{max-width:640px;margin:0 auto;background:var(--surface);border:1px solid var(--border2);border-radius:14px;display:flex;align-items:flex-end;gap:8px;padding:10px 10px 10px 18px;transition:border-color .2s;}
.bar-inner:focus-within{border-color:rgba(232,213,176,.2);}
#inp{flex:1;background:transparent;border:none;outline:none;font-family:'Inter',sans-serif;font-size:14px;font-weight:400;color:var(--text);resize:none;max-height:100px;line-height:1.5;padding:3px 0;}
#inp::placeholder{color:var(--text3);}
#snd{width:34px;height:34px;border-radius:9px;border:none;background:var(--send);color:var(--send-fg);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:opacity .15s,transform .15s;}
#snd:hover{opacity:.85;transform:scale(1.04);}
#snd:disabled{opacity:.25;cursor:default;transform:none;}

/* ANIMATIONS */
@keyframes up{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes breathe{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)}}
@keyframes tdot{0%,60%,100%{transform:translateY(0);opacity:.35}30%{transform:translateY(-5px);opacity:1}}

@media(max-width:540px){
  .hero{padding-top:56px;}
  .hero h1{font-size:24px;}
  .tab{padding:9px 12px;font-size:12px;}
  .bub{font-size:13px;}
  .bwrap{max-width:90%;}
  .cs-detail-meta{grid-template-columns:repeat(2,1fr);}
  .cs-panel-footer{flex-wrap:wrap;}
}
</style>
</head>
<body>
<div class="page">

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="av">PM</div>
    <div class="badge"><span class="bdot"></span>AI Portfolio Assistant</div>
    <h1>Ask anything about<br><span class="dim">Pradnya Malunjkar</span></h1>
    <p class="sub">Explore her work, experience and case studies through conversation.</p>

    <!-- TOP NAV TABS -->
    <nav class="tab-row">
      <button class="tab" onclick="tabClick(this,'Tell me about Pradnya — her background and design philosophy')">About Pradnya</button>
      <div class="tab-sep"></div>
      <button class="tab" onclick="tabClick(this,'Tell me about her work experience')">Work Experience</button>
      <div class="tab-sep"></div>
      <button class="tab" onclick="showCaseStudies(this)">Case Studies</button>
      <div class="tab-sep"></div>
      <a class="tab" href="https://bit.ly/42C4XWe" target="_blank" rel="noopener" onclick="setActive(this)">Download Resume</a>
      <div class="tab-sep"></div>
      <button class="tab" onclick="tabClick(this,'How can I contact Pradnya?')">Contact Pradnya</button>
    </nav>
  </section>

  <!-- CHAT -->
  <div class="chat" id="chat">
    <div class="sep">conversation</div>
    <div class="msgs" id="msgs"></div>
  </div>

</div><!-- /page -->

<!-- CASE STUDY DETAIL OVERLAY -->
<div class="cs-overlay" id="csOverlay" onclick="overlayClick(event)">
  <div class="cs-panel" id="csPanel">
    <div class="cs-panel-head">
      <span class="cs-panel-cat" id="pCat"></span>
      <button class="cs-close" onclick="closeDetail()" aria-label="Close">✕</button>
    </div>
    <div class="cs-panel-body" id="pBody"></div>
    <div class="cs-panel-footer" id="pFooter"></div>
  </div>
</div>

<!-- INPUT -->
<div class="bar">
  <div class="bar-inner">
    <textarea id="inp" rows="1" placeholder="Ask anything about Pradnya…"></textarea>
    <button id="snd" onclick="send()" aria-label="Send">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </div>
</div>

<script>
