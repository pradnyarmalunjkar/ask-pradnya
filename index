      { title: 'Journey-First Navigation', desc: 'Designed navigation around visitor goals (Plan Visit, Explore Now, My Itinerary) rather than content categories, mapping to the natural flow of how guests experience the destination.' },
      { title: 'Multi-Language Design System', desc: 'Built a full Arabic/English bilingual design system with RTL/LTR layout switching, ensuring cultural appropriateness and accessibility for all visitor segments.' },
      { title: 'VIP User Flow Separation', desc: 'Created a distinct but connected VIP experience flow with premium entry points, exclusive content, and concierge-style interactions without disrupting the standard visitor journey.' },
    ],
    outcomes: [
      'Unified digital presence reduced visitor confusion across fragmented touchpoints',
      'VIP journey planning moved fully in-app, eliminating staff manual coordination',
      'Full Arabic/English bilingual support across all user flows',
      'Delivered interactive Figma prototypes for smooth developer handoff',
    ],
  },
  {
    id: 'travelx',
    category: 'B2C Super App UX',
    title: 'TravelX VIP — All-in-One Travel Super App',
    description: 'Designing a comprehensive travel platform covering Duty-Free, Lounge Access, Flights, Hotels, Live Tracking, eSIMs, and Attractions for global airline and bank partners.',
    client: 'Scandid / Wishpoint Tech',
    duration: '~2 Years',
    role: 'Sr. UI/UX Designer',
    platform: 'Mobile App & Web',
    industry: 'Travel / Fintech',
    behance: 'https://www.behance.net/pradnyamalunjkar',
