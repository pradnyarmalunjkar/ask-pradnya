async function send(custom){
  const inp = document.getElementById('inp');
  const text = (custom!==undefined ? custom : inp.value).trim();
  if(!text||busy) return;
  inp.value=''; inp.style.height='auto';
  busy=true; document.getElementById('snd').disabled=true;

  const q = text;
  hist.push({role:'user', content:text});
  render(false);
  showTyping();

  try{
    const msgs = hist.filter(m=>m.role==='user'||m.role==='assistant').map(m=>({role:m.role,content:m.content}));
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:SYS,messages:msgs})
    });
    const data = await res.json();
    const reply = data.content?.[0]?.text||"Feel free to reach out at malunjkar.pradnya@gmail.com!";
    hideTyping();
    hist.push({role:'assistant',content:reply});
    render(shouldTab(q));
  } catch{
    hideTyping();
    hist.push({role:'assistant',content:"Something went wrong. Reach me at malunjkar.pradnya@gmail.com!"});
    render(false);
  }
  busy=false; document.getElementById('snd').disabled=false;
}

