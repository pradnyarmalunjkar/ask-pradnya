function fmt(t){
  t = t.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>');
  const lines = t.split('\n');
  let out='', list=false;
  for(const l of lines){
    if(/^[-•*]\s/.test(l)){
      if(!list){out+='<ul>';list=true;}
      out+='<li>'+l.replace(/^[-•*]\s/,'')+'</li>';
    } else {
      if(list){out+='</ul>';list=false;}
      out+=l+'\n';
    }
  }
  if(list) out+='</ul>';
  return out.replace(/\n{2,}/g,'</p><p>').replace(/\n/g,'<br>');
}

